# ──────────────────────────────────────────────────────────────────────
# AI Policy Builder — environment variables
#
# These are NEXT_PUBLIC_* because the HubSpot Forms API and the
# Calendly slugs are public-by-design (same info their official embed
# snippets expose). No private API keys are required for the v1 flow.
# Copy this file to `.env.local` and fill in the values.
# ──────────────────────────────────────────────────────────────────────

# HubSpot Forms API — see lib/hubspot.ts for the submit endpoint shape.
# Create a form in HubSpot → Marketing → Forms → copy the IDs from the
# "Share" / embed snippet.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
NEXT_PUBLIC_HUBSPOT_FORM_GUID=

# Calendly slugs — set the public scheduling links for each team. The
# Done step shows two buttons that open these URLs in a new tab.
NEXT_PUBLIC_CALENDLY_POLICY_URL=https://calendly.com/cloudstaff-ai-policy/30min
NEXT_PUBLIC_CALENDLY_DEV_URL=https://calendly.com/cloudstaff-ai-dev/30min
